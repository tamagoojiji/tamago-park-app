.calendarSection {
  padding: var(--content-padding);
  animation: fadeSlideIn 0.5s ease;
}

/* 月ナビゲーション */
.monthNav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  margin-bottom: 12px;
}

.navButton {
  font-size: 22px;
  color: var(--color-primary);
  padding: 6px 14px;
  font-weight: 700;
  background: var(--color-bg-card);
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-card);
  transition: all 0.15s;
}

.navButton:active {
  transform: scale(0.95);
}

.monthLabel {
  font-size: var(--text-xl);
  font-weight: 800;
  color: var(--color-text);
}

/* カレンダーカード */
.calendarCard {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 12px 8px;
  box-shadow: var(--shadow-card);
  margin-bottom: 12px;
}

/* 曜日ヘッダー */
.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 4px;
}

.weekday {
  font-size: var(--text-xxs);
  font-weight: 700;
  color: var(--color-text-sub);
  padding: 6px 0;
}

.weekday.sunday {
  color: var(--color-red);
}

.weekday.saturday {
  color: var(--color-primary);
}

/* カレンダーグリッド */
.daysGrid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 2px;
}

.day {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4px 0;
  min-height: 52px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.15s;
  gap: 1px;
}

.day:active {
  transform: scale(0.93);
}

.emptyDay {
  min-height: 52px;
}

.dayNumber {
  font-size: var(--text-xs);
  font-weight: 700;
  line-height: 1;
}

.weatherIcon {
  font-size: 12px;
  line-height: 1;
}

.hoursLabel {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 8px;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.excludedLabel {
  font-size: 10px;
  font-weight: 800;
  color: var(--color-red);
  line-height: 1;
}

.availableLabel {
  font-size: 10px;
  font-weight: 800;
  color: var(--color-green);
  line-height: 1;
}

/* チケット価格ラベル */
.priceLabel {
  font-size: 7px;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
}

.price_low {
  color: var(--color-green);
}

.price_mid {
  color: var(--color-primary);
}

.price_high {
  color: var(--color-accent);
}

.price_peak {
  color: var(--color-red);
}

/* 今日 */
.today {
  background: var(--color-primary);
  border-radius: 10px;
}

.today .dayNumber {
  color: #fff;
  font-weight: 800;
}

.today .weatherIcon {
  filter: brightness(1.2);
}

.today .hoursLabel,
.today .excludedLabel,
.today .availableLabel,
.today .priceLabel,
.today .privateLabel {
  color: rgba(255, 255, 255, 0.9);
}

/* 選択中 */
.selected {
  background: #E3F0FC;
  border-radius: 10px;
  box-shadow: inset 0 0 0 2px var(--color-primary);
}

.today.selected {
  background: var(--color-primary);
  box-shadow: inset 0 0 0 2px var(--color-primary-dark);
}

/* 曜日色 */
.sunday .dayNumber {
  color: var(--color-red);
}

.saturday .dayNumber {
  color: var(--color-primary);
}

.today.sunday .dayNumber,
.today.saturday .dayNumber {
  color: #fff;
}

/* 日付詳細カード */
.detailCard {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-card);
  border-left: 4px solid var(--color-primary);
  animation: fadeIn 0.3s ease;
}

.detailHeader {
  margin-bottom: 10px;
}

.detailDate {
  font-size: var(--text-md);
  font-weight: 800;
  color: var(--color-text);
}

/* 詳細カード 情報行 */
.infoRow {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid var(--color-border);
}

.infoRow:last-child {
  border-bottom: none;
}

.infoIcon {
  font-size: 18px;
  width: 24px;
  text-align: center;
  flex-shrink: 0;
}

.infoLabel {
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-text-sub);
  width: 72px;
  flex-shrink: 0;
}

.infoValue {
  font-size: var(--text-sm);
  font-weight: 800;
  color: var(--color-text);
  margin-left: auto;
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.tempMax {
  font-size: var(--text-base);
  font-weight: 800;
  color: var(--color-red);
}

.tempSep {
  font-size: var(--text-xs);
  color: var(--color-text-light);
}

.tempMin {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-primary);
}

.precipitation {
  font-size: var(--text-xxs);
  font-weight: 700;
  color: var(--color-text-sub);
  margin-left: 4px;
}

/* 価格テキスト色 */
.priceText_low { color: var(--color-green); }
.priceText_mid { color: var(--color-primary); }
.priceText_high { color: var(--color-accent); }
.priceText_peak { color: var(--color-red); }

/* 貸切ラベル */
.privateLabel {
  font-size: 8px;
  font-weight: 800;
  color: var(--color-red);
  line-height: 1;
}

/* テキスト色ユーティリティ */
.textRed { color: var(--color-red); font-weight: 700; }
.textGreen { color: var(--color-green); }
.textGray { color: var(--color-text-light); font-weight: 600; }

/* 詳細カード 右側を縦並びにする */
.infoValueCol {
  margin-left: auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
  font-size: var(--text-xs);
}

.infoSubText {
  font-size: var(--text-xxs);
  color: var(--color-text-sub);
  font-weight: 600;
}


/* タブ情報 */
.tabInfo {
  padding: 4px 0 0;
}

.tabInfoText {
  font-size: var(--text-sm);
  color: var(--color-text);
  font-weight: 600;
}

.tabInfoEmpty {
  font-size: var(--text-xs);
  color: var(--color-text-light);
  text-align: center;
  padding: 4px 0;
}

/* タブ */
.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-bottom: 12px;
}

.tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 10px 4px;
  background: var(--color-bg-card);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-sm);
  transition: all 0.2s;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.tab:active {
  transform: scale(0.97);
}

.tabIcon {
  font-size: 18px;
  line-height: 1;
}

.tabLabel {
  font-size: var(--text-tiny);
  font-weight: 700;
  color: var(--color-text-sub);
}

.activeTab {
  background: var(--color-primary);
  border-color: var(--color-primary);
  box-shadow: 0 2px 8px rgba(74, 144, 217, 0.3);
}

.activeTab .tabLabel {
  color: #fff;
}

/* タブコンテンツ */
.tabContent {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--card-padding);
  min-height: 60px;
  box-shadow: var(--shadow-card);
  animation: fadeIn 0.3s ease;
}

.tabPlaceholder {
  text-align: center;
  color: var(--color-text-light);
  font-size: var(--text-sm);
  padding: 12px 0;
}

.tabHint {
  font-size: var(--text-xxs);
  color: var(--color-coming-soon);
}

@media (max-width: 380px) {
  .dayNumber {
    font-size: var(--text-xxs);
  }

  .weatherIcon {
    font-size: 10px;
  }

  .tab {
    padding: 8px 2px;
  }

  .tabIcon {
    font-size: 16px;
  }

  .tabLabel {
    font-size: 10px;
  }
}
